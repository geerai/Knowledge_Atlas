    public void ApplyGeometry()
    {
        if (floor !=3D null)
        {
            floor.localScale =3D new Vector3(roomWidth, 0.1f, roomDepth);
            floor.localPosition =3D Vector3.zero;
        }

        if (ceiling !=3D null)
        {
