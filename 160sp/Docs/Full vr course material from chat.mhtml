    }

    public void SetRoomWidth(float value) { roomWidth =3D value; ApplyGeome=
try(); }
    public void SetRoomDepth(float value) { roomDepth =3D value; ApplyGeome=
try(); }
    public void SetCeilingHeight(float value) { ceilingHeight =3D value; Ap=
plyGeometry(); }
