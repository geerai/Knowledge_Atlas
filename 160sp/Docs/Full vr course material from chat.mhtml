            ceiling.localPosition =3D new Vector3(0f, ceilingHeight, 0f);
        }

        float wallThickness =3D 0.1f;
        float halfWidth =3D roomWidth * 0.5f;
        float halfDepth =3D roomDepth * 0.5f;
        float wallY =3D ceilingHeight * 0.5f;

        if (wallNorth !=3D null)
        {
            wallNorth.localScale =3D new Vector3(roomWidth, ceilingHeight, =
wallThickness);
            wallNorth.localPosition =3D new Vector3(0f, wallY, halfDepth);
        }

        if (wallSouth !=3D null)
        {
            wallSouth.localScale =3D new Vector3(roomWidth, ceilingHeight, =
wallThickness);
            wallSouth.localPosition =3D new Vector3(0f, wallY, -halfDepth);
        }

        if (wallEast !=3D null)
        {
            wallEast.localScale =3D new Vector3(wallThickness, ceilingHeigh=
t, roomDepth);
            wallEast.localPosition =3D new Vector3(halfWidth, wallY, 0f);
        }

        if (wallWest !=3D null)
        {
            wallWest.localScale =3D new Vector3(wallThickness, ceilingHeigh=
t, roomDepth);
            wallWest.localPosition =3D new Vector3(-halfWidth, wallY, 0f);
        }

        if (windowNorth !=3D null)
        {
            float sillHeight =3D Mathf.Clamp(ceilingHeight * 0.45f, 0.6f, c=
eilingHeight - 0.6f);
            windowNorth.localScale =3D new Vector3(windowWidth, windowHeigh=
t, 0.05f);
            windowNorth.localPosition =3D new Vector3(0f, sillHeight, halfD=
epth + 0.01f);
